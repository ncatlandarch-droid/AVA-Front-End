rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'ncatlandarch@gmail.com' ||
        request.auth.token.email.matches('.*ncatlandarch.*')
      );
    }

    // Community design images — authenticated upload, admin delete
    match /designs/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    // Project baseline images and videos — admin only
    // Path: projects/{projectId}/{filename} — two-level deep match required
    match /projects/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 50 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Default: deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
